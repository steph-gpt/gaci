# ─────────────────────────────────────────────
# GACI — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control
# ─────────────────────────────────────────────

# ── Anthropic ──────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Jira ───────────────────────────────────────
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_USER_EMAIL=your-jira-email@yourorg.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=PROD

# Jira field IDs for the GACI registry fields
# These vary per Jira instance — find yours in Jira > Settings > Issues > Custom Fields
JIRA_FIELD_PRODUCT_STATUS=customfield_10001
JIRA_FIELD_CONTENT_SCOPE=customfield_10002
JIRA_FIELD_DEPRECATION_REASON=customfield_10003
JIRA_FIELD_SUCCESSOR_FEATURE=customfield_10004
JIRA_FIELD_SUNSET_DATE=customfield_10005

# Status name in your Jira that triggers content generation
# Comma-separated if multiple statuses should trigger
JIRA_TRIGGER_STATUSES=QA Ready,GA,Release Notes Published

# ── Webhook Server ─────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
# Optional secret for validating Jira webhook payloads
WEBHOOK_SECRET=your-webhook-secret-here

# ── Knowledge Repository ────────────────────────
# Path to the knowledge-repo directory (relative to project root)
KNOWLEDGE_REPO_PATH=./knowledge-repo
# Your organisation name — becomes the top-level folder in knowledge-repo
ORG_NAME=example-org

# ── Vector Store (ChromaDB) ─────────────────────
CHROMA_PERSIST_PATH=./chroma-db
CHROMA_COLLECTION_NAME=gaci-knowledge

# ── Audit Log ──────────────────────────────────
AUDIT_DB_PATH=./audit.db

# ── Escalation ─────────────────────────────────
# Hours before an outstanding co-owner approval triggers a second escalation
ESCALATION_THRESHOLD_HOURS=48
# Jira account ID of the department head to tag on second escalation
# Comma-separated if multiple
ESCALATION_FALLBACK_ASSIGNEE=jira-account-id-here

# ── Confidence Thresholds ──────────────────────
# Agent will flag draft RED in Jira if confidence is below this value
CS_AGENT_CONFIDENCE_FLOOR=0.75
INCIDENT_AGENT_CONFIDENCE_FLOOR=0.90

# ── Variance Detection Agent ───────────────────
VDA_MONITORING_THRESHOLD=0.20
VDA_REVIEW_THRESHOLD=0.40
VDA_ESCALATION_THRESHOLD=0.60
VDA_ROLLING_WINDOW_DAYS=30

# ── Logging ────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./gaci.log
